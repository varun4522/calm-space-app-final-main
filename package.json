{
  "name": "calm-space",
  "main": "expo-router/entry",
  "version": "1.0.1",
  "scripts": {
    "start": "expo start",
    "start:with-ai": "concurrently --kill-others \"node start-ai-simple.js\" \"expo start\"",
    "start:with-enhanced-ai": "concurrently --kill-others \"node start-ai-enhanced.js\" \"expo start\"",
    "start:expo": "expo start",
    "start:ai": "node start-ai-simple.js",
    "start:ai-enhanced": "node start-ai-enhanced.js",
    "start:ai-only": "cd chatbot && python main.py",
    "start:ai-enhanced-only": "cd chatbot && python main_enhanced.py",
    "start:production": "cd chatbot && python server_manager.py",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "dev": "npm run start:with-enhanced-ai",
    "production": "npm run start:production",
    "build": "expo build",
    "publish": "expo publish",
    "lint": "expo lint",
    "git:quick": "node scripts/git-quick-update.js"
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.6",
    "@expo/vector-icons": "^15.0.2",
    "@openspacelabs/react-native-zoomable-view": "^2.4.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-native-community/slider": "5.1.2",
    "@react-native-picker/picker": "2.11.4",
    "@shopify/react-native-skia": "2.4.18",
    "@supabase/supabase-js": "^2.50.2",
    "@tanstack/react-query": "^5.90.2",
    "base64-js": "^1.5.1",
    "expo": "~55.0.17",
    "expo-asset": "~55.0.10",
    "expo-audio": "~55.0.14",
    "expo-av": "~16.0.8",
    "expo-clipboard": "~55.0.13",
    "expo-constants": "~55.0.9",
    "expo-dev-client": "~55.0.28",
    "expo-document-picker": "~55.0.13",
    "expo-file-system": "~55.0.11",
    "expo-font": "~55.0.4",
    "expo-image": "~55.0.9",
    "expo-image-picker": "~55.0.19",
    "expo-linear-gradient": "~55.0.13",
    "expo-linking": "~55.0.14",
    "expo-location": "~55.1.8",
    "expo-notifications": "~55.0.20",
    "expo-router": "~55.0.13",
    "expo-secure-store": "~55.0.13",
    "expo-sharing": "~55.0.18",
    "expo-splash-screen": "~55.0.19",
    "expo-status-bar": "~55.0.5",
    "expo-updates": "~55.0.21",
    "expo-video": "~55.0.15",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-chart-kit": "^6.12.0",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-paper": "^5.14.5",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-toast-message": "^2.3.3",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-view-shot": "4.0.3",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.4"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/node": "^24.7.1",
    "@types/react": "~19.2.10",
    "concurrently": "^9.2.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~55.0.0",
    "expo-module-scripts": "^3.0.5",
    "typescript": "~5.9.2"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-chart-kit"
        ]
      }
    }
  },
  "private": true
}
